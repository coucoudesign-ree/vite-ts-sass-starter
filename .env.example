# ===========================================
# .env.example（Vite + Sass Starter Template）
# -------------------------------------------
# このファイルをコピーして環境別設定を作成します。
# 例：
#   cp .env.example .env.dev       → 開発確認用（非公開）
#   cp .env.example .env.deliver   → 本番・納品用（公開OK）
# -------------------------------------------
# 🗓️ 2025-12-19 JST
# ===========================================

# ===========================================
# 🌐 SITE基本設定
# -------------------------------------------
# 開発時 / 本番時のサイトURL
# - dev：ローカル確認用URL（例：https://dev-check.test）
# - deliver：本番・納品先URL（例：https://example.com）
# ===========================================
VITE_SITE_URL=https://example.com

# ローカルWordPressサイトURL（Vite devサーバーのプロキシ先）
# プロジェクトごとに変更してください
VITE_WP_URL=http://wp-vite-lab.local

# ===========================================
# 🧩 OGP設定
# -------------------------------------------
# 各ページのOGP出力に利用されます。
# ===========================================
VITE_OG_TITLE=Vite Starter Template
VITE_OG_DESCRIPTION=Frontend starter built with Vite + TypeScript + Sass
VITE_OG_IMAGE=https://example.com/ogp.jpg
VITE_OG_URL=${VITE_SITE_URL}

# ===========================================
# 🧱 メタ・ブランド設定
# -------------------------------------------
# サイト全体で共通して利用される値
# ===========================================
VITE_SITE_NAME=Vite Starter
VITE_THEME_COLOR=#ffffff

# ===========================================
# 📊 アナリティクス・タグ（任意）
# -------------------------------------------
# Google Tag ManagerなどのIDを設定
# 例: GTM-XXXXXXX
# ===========================================
VITE_GTM_ID=

# ===========================================
# 📸 Instagram（任意）
# -------------------------------------------
# instagram.ts を使用する場合に設定
# ===========================================
VITE_INSTAGRAM_TOKEN=
VITE_INSTAGRAM_USER_ID=

# ===========================================
# 📬 フォーム送信設定（api/sendmail.php 用）
# -------------------------------------------
# PHP 側の環境変数として参照されます。
# Vercel: Project Settings > Environment Variables に設定
# 通常サーバー: .env.php や php.ini で設定
# -------------------------------------------
# ⚠️ プロジェクトごとに必ず変更する箇所
# ===========================================

# 管理者の受信メールアドレス（カンマ区切りで複数可）
MAIL_TO=admin@example.com

# 送信元メールアドレス（サーバーの許可ドメインに合わせること）
MAIL_FROM=no-reply@example.com

# メール件名・本文に使用するサイト名
SITE_NAME=サイト名を入力

# フォーム送信完了後のリダイレクト先URL（サンクスページ）
THANKS_URL=/thanks.html

# フォームからのリクエストを許可するオリジン（CORS用）
# 例: https://example.com
# 開発時は http://localhost:5174 など Vite サーバーのURL
ALLOWED_ORIGIN=http://localhost:5174

# 許可ホスト名（カンマ区切り。空の場合は全オリジン許可）
ALLOWED_HOSTS=localhost

# ===========================================
# 🔗 フォームAPIベースURL（VITE_API_URL）
# -------------------------------------------
# 静的ホスティング（Vercel等）とPHPサーバー（ロリポップ等）を
# 分けて運用する場合に、PHP側のベースURLを指定します。
# 同一オリジンで運用する場合は空欄のままにしてください。
# 例: https://your-domain.com
# ===========================================
VITE_API_URL=
